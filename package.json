{
  "name": "quickinvoice",
  "version": "1.0.0",
  "description": "Invoice management platform for freelancers",
  "private": true,
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "jest",
    "test:unit": "jest tests/unit --passWithNoTests",
    "test:integration": "jest tests/integration --passWithNoTests",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "deploy:dev": "sam deploy --config-env dev",
    "deploy:prod": "sam deploy --config-env prod",
    "local": "sam local start-api --env-vars .env.local.json"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.750.0",
    "@aws-sdk/client-ses": "3.750.0",
    "@aws-sdk/client-secrets-manager": "3.750.0",
    "@aws-sdk/lib-dynamodb": "3.750.0",
    "bcryptjs": "2.4.3",
    "jsonwebtoken": "9.0.2",
    "pdfkit": "0.15.0",
    "uuid": "9.0.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.145",
    "@types/bcryptjs": "2.4.6",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.17.30",
    "@types/pdfkit": "0.13.9",
    "@types/uuid": "9.0.8",
    "fast-check": "3.22.0",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "typescript": "5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
